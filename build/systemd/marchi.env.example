# Copy to /etc/marchi/marchi.env and set permissions:
#   install -o marchi -g marchi -m 0600 marchi.env.example /etc/marchi/marchi.env
#
# Optional. Without this file the service starts locked (NFR-SC-01) and
# stays locked until someone opens the web UI and unlocks it by hand —
# every restart otherwise needs that same manual step. Setting the
# Master Key here trades that off against the key living in a plaintext
# file on disk, root-readable only if the permissions above are applied.
MARCHI_MASTER_KEY=
